{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "assets/*.png",
      "use": "@vercel/static"
    },
    {
      "src": "assets/*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "assets/*.jpeg",
      "use": "@vercel/static"
    },
    {
      "src": "assets/*.svg",
      "use": "@vercel/static"
    },
    {
      "src": "assets/*.webp",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}