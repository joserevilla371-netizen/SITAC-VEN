# .env.example - Plantilla de configuración
# Copia este archivo como .env y rellena con tus credenciales reales.

FIREBASE_API_KEY=tu_api_key_aqui
FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
FIREBASE_DATABASE_URL=https://tu_proyecto-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=tu_proyecto_id
FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx
TELEGRAM_TOKEN=tu_token_de_bot_aqui
CHAT_ID=tu_id_de_chat_aqui